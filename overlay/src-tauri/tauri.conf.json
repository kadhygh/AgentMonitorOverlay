{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Monitor Overlay",
  "version": "0.1.2",
  "identifier": "local.agent-monitor.overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Agent Monitor Overlay",
        "width": 380,
        "height": 520,
        "minWidth": 264,
        "minHeight": 86,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": false,
        "center": false,
        "x": 1520,
        "y": 120
      },
      {
        "label": "scratchpad",
        "title": "AMO Scratchpad",
        "width": 480,
        "height": 320,
        "minWidth": 340,
        "minHeight": 220,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false
      },
      {
        "label": "deploy",
        "title": "AMO Workspace Center",
        "width": 1000,
        "height": 640,
        "minWidth": 760,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      },
      {
        "label": "settings",
        "title": "AMO Settings",
        "width": 660,
        "height": 500,
        "minWidth": 540,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
